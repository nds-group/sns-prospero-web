---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/outfit/600.css';
import '@fontsource/outfit/800.css';
import '@fontsource/cinzel/600.css';
import '@fontsource/cinzel/800.css';
import '@fontsource/cinzel/900.css';
import '@fontsource/lora/400.css';
import '@fontsource/lora/500.css';
import '@fontsource/lora/600.css';
import '@fontsource/lora/700.css';
import 'material-symbols/outlined.css';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="PROSPERO Project - Horizon Europe 6G Networks" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/images/project-logos/logo-notext.svg" />
		<title>{title}</title>
		
	</head>
	<body class="bg-background text-on-background font-body-md antialiased overflow-x-hidden selection:bg-primary-container selection:text-on-primary-container">
		
		<!-- TopNavBar -->
		<header class="fixed w-full top-0 z-50 bg-surface/80 backdrop-blur-md shadow-sm border-b border-glass-stroke">
			<div class="flex justify-between items-center h-20 px-8 max-w-container-max mx-auto">
				<a class="flex items-center gap-2 font-headline-md text-headline-md font-bold text-primary tracking-tight transition-transform hover:scale-95 duration-150 ease-in-out" href="/">
					<img src="/images/project-logos/logo-notext.svg" alt="PROSPERO Logo" class="h-10 w-10 object-contain" />
                    <span>PROSPERO</span>
				</a>
				<nav class="hidden md:flex items-center gap-5">
					<a class="text-on-surface-variant hover:text-primary transition-colors hover:bg-eco-surface/50 font-body-md text-body-md px-2 py-1 rounded transition-all duration-300" href="/">Home</a>
					<div class="relative group">
						<button class="text-on-surface-variant hover:text-primary transition-colors hover:bg-eco-surface/50 font-body-md text-body-md px-2 py-1 rounded transition-all duration-300 flex items-center gap-1" aria-haspopup="true">
							About
							<span class="material-symbols-outlined text-[18px]">expand_more</span>
						</button>
						<div class="absolute left-0 top-full pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
							<div class="w-56 bg-surface rounded-lg border border-glass-stroke shadow-[0_12px_30px_rgba(0,0,0,0.12)] p-2">
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/overview">Overview</a>
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/objectives">Objectives & Impact</a>
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/methodology">Methodology</a>
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/consortium">Consortium</a>
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/ethics">Ethics</a>
							</div>
						</div>
					</div>
					<div class="relative group">
						<button class="text-on-surface-variant hover:text-primary transition-colors hover:bg-eco-surface/50 font-body-md text-body-md px-2 py-1 rounded transition-all duration-300 flex items-center gap-1" aria-haspopup="true">
							Documentation
							<span class="material-symbols-outlined text-[18px]">expand_more</span>
						</button>
						<div class="absolute left-0 top-full pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
							<div class="w-56 bg-surface rounded-lg border border-glass-stroke shadow-[0_12px_30px_rgba(0,0,0,0.12)] p-2">
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/deliverables">Deliverables</a>
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/publications">Publications</a>
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/datasets">Datasets</a>
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/open-source">Open-Source Code</a>
							</div>
						</div>
					</div>
					<a class="text-on-surface-variant hover:text-primary transition-colors hover:bg-eco-surface/50 font-body-md text-body-md px-2 py-1 rounded transition-all duration-300" href="/media">News & Events</a>
					<div class="relative group">
						<button class="text-on-surface-variant hover:text-primary transition-colors hover:bg-eco-surface/50 font-body-md text-body-md px-2 py-1 rounded transition-all duration-300 flex items-center gap-1" aria-haspopup="true">
							Media
							<span class="material-symbols-outlined text-[18px]">expand_more</span>
						</button>
						<div class="absolute right-0 top-full pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
							<div class="w-48 bg-surface rounded-lg border border-glass-stroke shadow-[0_12px_30px_rgba(0,0,0,0.12)] p-2">
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/press">Press</a>
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/videos">Videos</a>
							</div>
						</div>
					</div>
				</nav>
			
				<!-- Mobile Menu Button -->
				<button class="md:hidden text-primary">
					<span class="material-symbols-outlined text-2xl">menu</span>
				</button>
			</div>
		</header>

		<slot />

		<!-- Footer -->
		<footer class="bg-primary w-full py-section-padding text-white relative overflow-hidden">
			<div class="absolute -inset-2 bg-prospero-texture-minimal-light bg-cover bg-no-repeat bg-center blur-sm opacity-80"></div>
			<div class="relative z-10 grid grid-cols-1 md:grid-cols-4 gap-gutter px-8 max-w-container-max mx-auto text-left">
				<div class="col-span-1 md:col-span-2 space-y-stack-sm">
					<img src="/images/project-logos/logo-horizontal.png" alt="PROSPERO Logo" class="h-12 w-auto object-contain brightness-0 invert mb-4" />
					<p class="font-body-md text-body-md text-white/80 max-w-sm">
						© 2026 PROSPERO Project. Co-funded by the European Union under Horizon Europe.
					</p>
					<div class="flex flex-wrap gap-3 pt-2">
						<a
							class="inline-flex items-center gap-2 font-body-md text-body-md text-white/80 hover:text-white transition-colors"
							href="https://www.instagram.com/prospero_sns/"
							target="_blank"
							rel="noreferrer"
							aria-label="PROSPERO on Instagram"
						>
							<span class="material-symbols-outlined text-[20px]">photo_camera</span>
							@prospero_sns
						</a>
						<a
							class="inline-flex items-center gap-2 font-body-md text-body-md text-white/80 hover:text-white transition-colors"
							href="https://www.linkedin.com/in/sns-prospero/"
							target="_blank"
							rel="noreferrer"
							aria-label="PROSPERO on LinkedIn"
						>
							<span class="material-symbols-outlined text-[20px]">business_center</span>
							LinkedIn
						</a>
					</div>
					<div class="flex gap-4 pt-4">
						<div class="h-12 w-24 flex items-center justify-center">
							<img src="/images/eu-logos/eu.svg" alt="European Union Logo" class="max-h-full max-w-full object-contain" />
						</div>
						<div class="h-12 w-24 flex items-center justify-center">
							<img src="/images/eu-logos/6G_sns.png" alt="Smart Networks and Services Joint Undertaking Logo" class="max-h-full max-w-full object-contain" />
						</div>
					</div>
				</div>
				<div class="space-y-stack-sm">
					<h5 class="font-label-sm text-label-sm text-white font-bold">Project</h5>
					<ul class="space-y-2">
						<li><a class="font-body-md text-body-md text-white/80 hover:text-white transition-colors hover:opacity-100" href="/overview">Overview</a></li>
						<li><a class="font-body-md text-body-md text-white/80 hover:text-white transition-colors hover:opacity-100" href="/objectives">Objectives & Impact</a></li>
						<li><a class="font-body-md text-body-md text-white/80 hover:text-white transition-colors hover:opacity-100" href="/consortium">Consortium</a></li>
						<li><a class="font-body-md text-body-md text-white/80 hover:text-white transition-colors hover:opacity-100" href="/media">News & Events</a></li>
					</ul>
				</div>
				<div class="space-y-stack-sm">
					<h5 class="font-label-sm text-label-sm text-white font-bold">Documentation</h5>
					<ul class="space-y-2">
						<li><a class="font-body-md text-body-md text-white/80 hover:text-white transition-colors hover:opacity-100" href="/deliverables">Deliverables</a></li>
						<li><a class="font-body-md text-body-md text-white/80 hover:text-white transition-colors hover:opacity-100" href="/publications">Publications</a></li>
						<li><a class="font-body-md text-body-md text-white/80 hover:text-white transition-colors hover:opacity-100" href="/datasets">Datasets</a></li>
						<li><a class="font-body-md text-body-md text-white/80 hover:text-white transition-colors hover:opacity-100" href="/open-source">Open-Source Code</a></li>
					</ul>
				</div>
			</div>
		</footer>
	</body>
</html>
