---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/cinzel/600.css';
import '@fontsource/cinzel/800.css';
import '@fontsource/cinzel/900.css';
import '@fontsource/lora/400.css';
import '@fontsource/lora/500.css';
import '@fontsource/lora/600.css';
import '@fontsource/lora/700.css';
import 'material-symbols/outlined.css';
import '../styles/global.css';
import { Image } from 'astro:assets';
import prosperoMark from '../../public/images/project-logos/logo-notext.svg';
import prosperoFooterLogo from '../../public/images/project-logos/logo-horizontal.png';
import europeanUnionLogo from '../../public/images/eu-logos/eu-white-outline.svg';
import snsLogo from '../../public/images/eu-logos/6G_sns.png';
import { socialLinks } from '../config/socialLinks';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="PROSPERO Project - Horizon Europe 6G Networks" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/images/project-logos/logo-notext.svg" />
		<title>{title}</title>
		
	</head>
	<body class="bg-background text-on-background font-body-md antialiased overflow-x-hidden selection:bg-primary-container selection:text-on-primary-container">
		
		<!-- TopNavBar -->
		<header class="fixed w-full top-0 z-50 bg-surface/80 backdrop-blur-md shadow-sm border-b border-glass-stroke">
			<div class="flex justify-between items-center h-20 px-8 max-w-container-max mx-auto">
				<a class="flex items-center gap-2 font-headline-md text-headline-md font-bold text-primary tracking-tight transition-colors duration-150 ease-in-out hover:text-sovereign-blue" href="/" aria-label="PROSPERO home">
					<Image src={prosperoMark} alt="PROSPERO Logo" class="h-10 w-10 object-contain" decoding="async" />
                    <span>PROSPERO</span>
				</a>
				<nav class="hidden md:flex items-center gap-5">
					<a class="text-on-surface-variant hover:text-primary transition-colors hover:bg-eco-surface/50 font-body-md text-body-md px-2 py-1 rounded transition-all duration-300" href="/">Home</a>
					<div class="relative group">
						<button class="text-on-surface-variant hover:text-primary transition-colors hover:bg-eco-surface/50 font-body-md text-body-md px-2 py-1 rounded transition-all duration-300 flex items-center gap-1" aria-haspopup="true">
							About
							<span class="material-symbols-outlined text-[18px]">expand_more</span>
						</button>
						<div class="absolute left-0 top-full pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
							<div class="w-56 bg-surface rounded-lg border border-glass-stroke shadow-[0_12px_30px_rgba(0,0,0,0.12)] p-2">
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/overview">Overview</a>
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/objectives">Objectives & Impact</a>
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/methodology">Methodology</a>
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/consortium">Consortium</a>
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/ethics">Ethics</a>
							</div>
						</div>
					</div>
					<div class="relative group">
						<button class="text-on-surface-variant hover:text-primary transition-colors hover:bg-eco-surface/50 font-body-md text-body-md px-2 py-1 rounded transition-all duration-300 flex items-center gap-1" aria-haspopup="true">
							Documentation
							<span class="material-symbols-outlined text-[18px]">expand_more</span>
						</button>
						<div class="absolute left-0 top-full pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
							<div class="w-56 bg-surface rounded-lg border border-glass-stroke shadow-[0_12px_30px_rgba(0,0,0,0.12)] p-2">
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/deliverables">Deliverables</a>
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/publications">Publications</a>
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/datasets">Datasets</a>
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/open-source">Open-Source Code</a>
							</div>
						</div>
					</div>
					<a class="text-on-surface-variant hover:text-primary transition-colors hover:bg-eco-surface/50 font-body-md text-body-md px-2 py-1 rounded transition-all duration-300" href="/media">News & Events</a>
					<div class="relative group">
						<button class="text-on-surface-variant hover:text-primary transition-colors hover:bg-eco-surface/50 font-body-md text-body-md px-2 py-1 rounded transition-all duration-300 flex items-center gap-1" aria-haspopup="true">
							Media
							<span class="material-symbols-outlined text-[18px]">expand_more</span>
						</button>
						<div class="absolute right-0 top-full pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
							<div class="w-48 bg-surface rounded-lg border border-glass-stroke shadow-[0_12px_30px_rgba(0,0,0,0.12)] p-2">
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/press">Press</a>
								<a class="block px-3 py-2 rounded text-on-surface-variant hover:text-primary hover:bg-eco-surface/50 transition-colors" href="/videos">Videos</a>
							</div>
						</div>
					</div>
				</nav>
			
				<!-- Mobile Menu Button -->
				<button
					id="mobile-menu-button"
					class="md:hidden inline-flex h-11 w-11 items-center justify-center rounded text-primary hover:bg-eco-surface/70 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-surface"
					type="button"
					aria-controls="mobile-menu"
					aria-expanded="false"
					aria-label="Open navigation menu"
				>
					<span class="material-symbols-outlined text-2xl" aria-hidden="true">menu</span>
				</button>
			</div>
			<nav
				id="mobile-menu"
				class="hidden md:hidden border-t border-glass-stroke bg-surface/95 px-8 py-4 shadow-sm"
				aria-label="Mobile navigation"
			>
				<div class="flex flex-col gap-1 max-w-container-max mx-auto">
					<a class="rounded px-3 py-2 text-on-surface-variant hover:bg-eco-surface/60 hover:text-primary transition-colors" href="/">Home</a>
					<p class="px-3 pt-3 pb-1 text-label-sm font-bold uppercase text-primary">About</p>
					<a class="rounded px-3 py-2 text-on-surface-variant hover:bg-eco-surface/60 hover:text-primary transition-colors" href="/overview">Overview</a>
					<a class="rounded px-3 py-2 text-on-surface-variant hover:bg-eco-surface/60 hover:text-primary transition-colors" href="/objectives">Objectives & Impact</a>
					<a class="rounded px-3 py-2 text-on-surface-variant hover:bg-eco-surface/60 hover:text-primary transition-colors" href="/methodology">Methodology</a>
					<a class="rounded px-3 py-2 text-on-surface-variant hover:bg-eco-surface/60 hover:text-primary transition-colors" href="/consortium">Consortium</a>
					<a class="rounded px-3 py-2 text-on-surface-variant hover:bg-eco-surface/60 hover:text-primary transition-colors" href="/ethics">Ethics</a>
					<p class="px-3 pt-3 pb-1 text-label-sm font-bold uppercase text-primary">Documentation</p>
					<a class="rounded px-3 py-2 text-on-surface-variant hover:bg-eco-surface/60 hover:text-primary transition-colors" href="/deliverables">Deliverables</a>
					<a class="rounded px-3 py-2 text-on-surface-variant hover:bg-eco-surface/60 hover:text-primary transition-colors" href="/publications">Publications</a>
					<a class="rounded px-3 py-2 text-on-surface-variant hover:bg-eco-surface/60 hover:text-primary transition-colors" href="/datasets">Datasets</a>
					<a class="rounded px-3 py-2 text-on-surface-variant hover:bg-eco-surface/60 hover:text-primary transition-colors" href="/open-source">Open-Source Code</a>
					<a class="rounded px-3 py-2 text-on-surface-variant hover:bg-eco-surface/60 hover:text-primary transition-colors" href="/media">News & Events</a>
					<p class="px-3 pt-3 pb-1 text-label-sm font-bold uppercase text-primary">Media</p>
					<a class="rounded px-3 py-2 text-on-surface-variant hover:bg-eco-surface/60 hover:text-primary transition-colors" href="/press">Press</a>
					<a class="rounded px-3 py-2 text-on-surface-variant hover:bg-eco-surface/60 hover:text-primary transition-colors" href="/videos">Videos</a>
				</div>
			</nav>
		</header>

		<slot />

		<!-- Footer -->
		<footer class="bg-primary w-full py-section-padding text-white relative overflow-hidden">
			<div class="absolute -inset-2 bg-prospero-texture-minimal-light bg-cover bg-no-repeat bg-center blur-sm opacity-80"></div>
			<div class="relative z-10 px-8 max-w-container-max mx-auto text-left">
				<div class="flex flex-col gap-gutter md:flex-row md:items-start md:justify-between">
					<div class="space-y-stack-sm md:w-[min(34rem,50%)]">
						<Image src={prosperoFooterLogo} alt="PROSPERO Logo" class="h-12 w-auto object-contain brightness-0 invert mb-4" loading="lazy" decoding="async" />
						<p class="font-body-md text-body-md text-white/80 max-w-sm">
							© 2026 PROSPERO Project. Co-funded by the European Union under Horizon Europe.
						</p>
						<div class="flex flex-wrap gap-x-4 gap-y-2 pt-2">
							{socialLinks.map((link) => (
								<a
									class="inline-flex items-center gap-2 font-body-md text-body-md text-white/80 hover:text-white transition-colors"
									href={link.href}
									target="_blank"
									rel="noreferrer"
									aria-label={link.label}
								>
									<span class="material-symbols-outlined text-[20px]" aria-hidden="true">{link.icon}</span>
									{link.name}
								</a>
							))}
						</div>
					</div>
					<div class="grid grid-cols-1 gap-gutter sm:grid-cols-2 md:ml-auto md:gap-16">
						<div class="space-y-stack-sm md:w-40">
							<h5 class="font-label-sm text-label-sm text-white font-bold">Project</h5>
							<ul class="space-y-2">
								<li><a class="font-body-md text-body-md text-white/80 hover:text-white transition-colors hover:opacity-100" href="/overview">Overview</a></li>
								<li><a class="font-body-md text-body-md text-white/80 hover:text-white transition-colors hover:opacity-100" href="/objectives">Objectives & Impact</a></li>
								<li><a class="font-body-md text-body-md text-white/80 hover:text-white transition-colors hover:opacity-100" href="/consortium">Consortium</a></li>
								<li><a class="font-body-md text-body-md text-white/80 hover:text-white transition-colors hover:opacity-100" href="/media">News & Events</a></li>
							</ul>
						</div>
						<div class="space-y-stack-sm md:w-40">
							<h5 class="font-label-sm text-label-sm text-white font-bold">Documentation</h5>
							<ul class="space-y-2">
								<li><a class="font-body-md text-body-md text-white/80 hover:text-white transition-colors hover:opacity-100" href="/deliverables">Deliverables</a></li>
								<li><a class="font-body-md text-body-md text-white/80 hover:text-white transition-colors hover:opacity-100" href="/publications">Publications</a></li>
								<li><a class="font-body-md text-body-md text-white/80 hover:text-white transition-colors hover:opacity-100" href="/datasets">Datasets</a></li>
								<li><a class="font-body-md text-body-md text-white/80 hover:text-white transition-colors hover:opacity-100" href="/open-source">Open-Source Code</a></li>
							</ul>
						</div>
					</div>
				</div>
				<div class="mt-12 flex w-full items-center justify-between gap-8 border-t border-white/20 pt-8">
					<div class="md:w-[min(34rem,50%)] flex justify-start">
						<Image src={europeanUnionLogo} alt="European Union Logo" class="h-14 w-32 object-contain object-left" loading="lazy" decoding="async" />
					</div>
					<div class="h-14 w-40 flex items-center justify-end">
						<Image src={snsLogo} alt="Smart Networks and Services Joint Undertaking Logo" class="max-h-full max-w-full object-contain brightness-0 invert" loading="lazy" decoding="async" />
					</div>
				</div>
			</div>
		</footer>
		<script>
			const mobileMenuButton = document.querySelector<HTMLButtonElement>('#mobile-menu-button');
			const mobileMenu = document.querySelector<HTMLElement>('#mobile-menu');
			const mobileMenuIcon = mobileMenuButton?.querySelector('.material-symbols-outlined');

			const setMobileMenuOpen = (isOpen: boolean) => {
				if (!mobileMenuButton || !mobileMenu || !mobileMenuIcon) return;

				mobileMenu.classList.toggle('hidden', !isOpen);
				mobileMenuButton.setAttribute('aria-expanded', String(isOpen));
				mobileMenuButton.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
				mobileMenuIcon.textContent = isOpen ? 'close' : 'menu';
			};

			mobileMenuButton?.addEventListener('click', () => {
				const isOpen = mobileMenuButton.getAttribute('aria-expanded') === 'true';
				setMobileMenuOpen(!isOpen);
			});

			mobileMenu?.addEventListener('click', (event) => {
				if ((event.target as HTMLElement).closest('a')) {
					setMobileMenuOpen(false);
				}
			});

			window.addEventListener('resize', () => {
				if (window.matchMedia('(min-width: 768px)').matches) {
					setMobileMenuOpen(false);
				}
			});
		</script>
	</body>
</html>
