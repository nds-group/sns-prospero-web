---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import methodologyScheme from '../../public/images/stock/methodology-schem.png';

const phases = [
    {
        step: '1',
        title: 'Requirements and Architecture',
        body: 'WP2 starts from stakeholder needs, business cases, and standardisation input to define requirements for the project architecture, AI-6G, and cross-domain operation. These requirements guide the design of modules, interfaces, and operational procedures.',
    },
    {
        step: '2',
        title: 'Design of Innovations',
        body: 'WP3 transforms the architecture into detailed technical designs for TCO reduction, new revenue opportunities, and resiliency. It also defines validation concepts for the solutions later implemented in WP4.',
    },
    {
        step: '3',
        title: 'Implementation and Validation',
        body: 'WP4 implements prototypes and emulation-based validations for the designed innovations, covering energy-aware AI, vDU scaling, AI-driven services, and secure-by-default resiliency mechanisms.',
    },
    {
        step: '4',
        title: 'Impact and Standardisation',
        body: 'WP5 connects results to external stakeholders through communication, dissemination, exploitation, techno-economic analysis, standardisation contributions, open-source engagement, and technology transfer.',
    },
];

const workPackages = [
    ['WP1', 'Project Management & Coordination', 'TID', 'M1-M36'],
    ['WP2', 'UIS 6G System Architecture', 'UC3M', 'M1-M30'],
    ['WP3', 'Design of Innovations and Validation Concept', 'NOK', 'M3-M33'],
    ['WP4', 'Implementation, Viability, and Validation', 'IMDEA', 'M6-M36'],
    ['WP5', 'Communication, Exploitation, and Standardisation', 'RW', 'M1-M36'],
];

const businessCases = [
    {
        title: 'TCO reduction',
        body: 'Lowering CAPEX and OPEX through architectural simplification, energy-aware management, resource pooling, and efficient use of general-purpose compute infrastructure.',
    },
    {
        title: 'New business opportunities',
        body: 'Opening the 6G architecture to new services, marketplaces, AI workloads, and secure exposure of network capabilities for operators, enterprises, and third-party innovators.',
    },
    {
        title: 'Network resiliency',
        body: 'Building resilience into the architecture through zero-trust interactions, secure operations, emergency resource sharing, and continuity of critical communications.',
    },
];

const keyConcepts = [
    {
        acronym: 'GSBA',
        title: 'Global Service-Based Architecture',
        body: 'A service-based architecture that extends SBA principles across network and computing domains. PROSPERO builds on this concept towards virtualized, programmable service instances and codelets.',
    },
    {
        acronym: 'CCL',
        title: 'Compute Continuum Layer',
        body: 'A unified abstraction fabric for heterogeneous compute resources, from CPUs and GPUs to accelerators. It supports software RAN, resource pooling, energy efficiency, and distributed AI execution.',
    },
    {
        acronym: 'ZTL',
        title: 'Zero Trust Layer',
        body: 'A layer for secure and auditable interactions among entities in open distributed networks. PROSPERO extends this concept with hardware-anchored trust, trusted execution, and programmable in-network defence.',
    },
    {
        acronym: 'AI-6G',
        title: 'Network-native AI framework',
        body: 'A frugal, purpose-driven AI approach for 6G operations. PROSPERO organises it into AI-for-6G for automation, AI-and-6G for shared compute, and AI-on-6G for services built on network data.',
    },
    {
        acronym: 'KPIs',
        title: 'Technical and business indicators',
        body: 'Measures used to check whether each technical solution meets its expected performance contribution and supports the target business cases.',
    },
    {
        acronym: 'PoC',
        title: 'Proof-of-Concept evaluation',
        body: 'A dedicated validation activity used to test the practical viability of PROSPERO technical solutions against the project KPIs.',
    },
];

const validationFlow = [
    ['Strategic paradigms', 'Architectural simplification, global operation, AI-6G integration, sustainable network programming, and seamless network management.'],
    ['Technical solutions', 'AI/ML algorithms, analytical models, optimisation frameworks, and control systems designed around the project architectural components.'],
    ['PoC evaluations', 'Dedicated proof-of-concept validations measure technical performance and practical viability against project KPIs.'],
    ['Business feedback', 'Results are checked against TCO reduction, new revenue opportunities, and resiliency to refine or validate the solutions.'],
];

const strategicParadigms = [
    'Architectural simplification',
    'Global operation',
    'AI-6G integration',
    'Sustainable network programming',
    'Seamless network management',
];
---

<Layout title="Methodology - PROSPERO">
    <section class="relative pt-32 pb-section-padding overflow-hidden bg-surface bg-[url('/images/project-logos/getsitelogo.png')] bg-contain bg-center bg-no-repeat">
        <div class="absolute inset-0 bg-white/60 backdrop-blur-sm z-0"></div>
        <div class="max-w-container-max mx-auto px-8 relative z-10 text-center">
            <h1 class="font-display-lg text-display-lg tracking-tight text-sovereign-blue mb-stack-md">Methodology</h1>
            <p class="font-body-lg text-body-lg text-on-surface-variant max-w-3xl mx-auto">
                PROSPERO follows an iterative work plan that links architecture, solution design, implementation, validation, and impact activities throughout the 36-month project.
            </p>
        </div>
    </section>

    <section class="py-section-padding bg-surface-container-lowest">
        <div class="max-w-container-max mx-auto px-8">
            <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] gap-gutter items-start">
                <figure class="lg:col-span-2">
                    <div class="overflow-x-auto rounded-lg border border-glass-stroke bg-white p-4 shadow-[0_4px_20px_rgba(0,0,0,0.03)]">
                        <Image
                            src={methodologyScheme}
                            alt="PROSPERO methodology scheme showing business cases, strategic paradigms, architectural components, technical solutions, KPIs, and proof-of-concept validation"
                            class="h-auto w-full min-w-[820px] md:min-w-0"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                    <figcaption class="mt-4 font-body-md text-body-md text-on-surface-variant">
                        PROSPERO follows a methodological loop that links business cases, strategic paradigms, architectural components, technical solutions, KPIs, and proof-of-concept evaluations.
                    </figcaption>
                </figure>

                <div>
                    <h2 class="font-headline-lg text-headline-lg text-sovereign-blue mb-stack-md">Methodology at a Glance</h2>
                    <div class="space-y-stack-md font-body-lg text-body-lg text-on-surface-variant">
                        <p>
                            PROSPERO organises its methodology around three business cases: TCO reduction, new business opportunities, and network resiliency.
                        </p>
                        <p>
                            These business cases are addressed through five strategic paradigms that build on the project architectural components and are validated through measurable technical and business KPIs.
                        </p>
                    </div>
                </div>

                <div class="bg-white rounded-lg border border-glass-stroke p-6 shadow-[0_4px_20px_rgba(0,0,0,0.03)]">
                    <h3 class="font-headline-sm text-headline-sm text-primary mb-4">Strategic Paradigms</h3>
                    <ul class="space-y-3">
                        {strategicParadigms.map((item) => (
                            <li class="flex gap-2 font-body-md text-body-md text-on-surface-variant">
                                <span class="material-symbols-outlined text-primary text-[20px] mt-0.5">check_circle</span>
                                <span>{item}</span>
                            </li>
                        ))}
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="py-section-padding bg-surface">
        <div class="max-w-container-max mx-auto px-8">
            <div class="max-w-3xl mb-stack-lg">
                <h2 class="font-headline-lg text-headline-lg text-sovereign-blue mb-4">Terms Used in the Scheme</h2>
                <p class="font-body-lg text-body-lg text-on-surface-variant">
                    The scheme combines business goals, architectural models, and validation mechanisms. The following terms are the main building blocks needed to read it.
                </p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-section-padding">
                {businessCases.map((item) => (
                    <article class="bg-white rounded-lg p-6 border border-glass-stroke shadow-[0_4px_20px_rgba(0,0,0,0.03)]">
                        <p class="font-label-sm text-label-sm font-bold uppercase tracking-wide text-primary mb-3">Business case</p>
                        <h3 class="font-headline-md text-headline-md text-sovereign-blue mb-3">{item.title}</h3>
                        <p class="font-body-md text-body-md text-on-surface-variant">{item.body}</p>
                    </article>
                ))}
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                {keyConcepts.map((item) => (
                    <article class="bg-surface-container-lowest rounded-lg p-6 border border-glass-stroke">
                        <div class="flex items-start gap-4 mb-4">
                            <span class="inline-flex h-12 min-w-12 items-center justify-center rounded-lg bg-primary text-white font-bold text-sm">{item.acronym}</span>
                            <h3 class="font-headline-sm text-headline-sm text-on-background">{item.title}</h3>
                        </div>
                        <p class="font-body-md text-body-md text-on-surface-variant">{item.body}</p>
                    </article>
                ))}
            </div>

        </div>
    </section>

    <section class="py-section-padding bg-surface-container-lowest">
        <div class="max-w-container-max mx-auto px-8">
            <div class="bg-sovereign-blue text-white rounded-lg p-6 md:p-8">
                <h2 class="font-headline-lg text-headline-lg mb-4">Validation Loop</h2>
                <p class="font-body-lg text-body-lg text-white/80 max-w-3xl mb-6">
                    Technical solutions are evaluated through PoCs and checked against the initial business cases. The results either validate the solutions or feed updates back into their design.
                </p>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
                    {validationFlow.map(([title, body], index) => (
                        <div class="border border-white/20 rounded-lg p-5 bg-white/5">
                            <span class="font-label-sm text-label-sm font-bold text-eco-accent">0{index + 1}</span>
                            <h4 class="font-body-lg text-body-lg font-bold mt-2 mb-2">{title}</h4>
                            <p class="font-body-md text-body-md text-white/80">{body}</p>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <section class="py-section-padding bg-surface">
        <div class="max-w-container-max mx-auto px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-gutter mb-section-padding">
                <div>
                    <h2 class="font-headline-lg text-headline-lg text-sovereign-blue mb-stack-md">Work Plan and Iterations</h2>
                    <div class="space-y-stack-md font-body-lg text-body-lg text-on-surface-variant">
                        <p>
                            The work plan is organised in five work packages. WP2 defines requirements and architecture; WP3 develops technical designs and validation concepts; WP4 implements and evaluates the solutions; WP5 feeds stakeholder, business, standardisation, and dissemination input back into the technical work.
                        </p>
                        <p>
                            The interaction among work packages follows an iterative waterfall approach. Initial, intermediate, and final iterations support feedback across architecture, design, and validation through the 36-month project.
                        </p>
                    </div>
                </div>
                <div class="bg-white rounded-xl border border-glass-stroke shadow-[0_4px_20px_rgba(0,0,0,0.03)] overflow-hidden">
                    <div class="p-6 border-b border-surface-variant">
                        <h3 class="font-headline-md text-headline-md text-primary">Work Packages</h3>
                    </div>
                    <div class="divide-y divide-surface-variant">
                        {workPackages.map(([wp, title, lead, months]) => (
                            <div class="p-5 grid grid-cols-[64px_1fr] gap-4">
                                <span class="font-label-sm text-label-sm font-bold text-primary">{wp}</span>
                                <div>
                                    <h4 class="font-body-md text-body-md font-bold text-sovereign-blue">{title}</h4>
                                    <p class="font-body-md text-body-md text-on-surface-variant">Lead: {lead} · Timeline: {months}</p>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>

            <div>
                <h3 class="font-headline-md text-headline-md text-sovereign-blue mb-stack-lg">Work Package Flow</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    {phases.map((phase) => (
                        <article class="bg-surface-container-lowest rounded-xl p-8 border border-glass-stroke shadow-[0_4px_20px_rgba(0,0,0,0.03)] relative pt-12">
                            <div class="w-12 h-12 bg-eco-surface text-primary rounded-full flex items-center justify-center font-bold text-lg absolute -top-6 left-1/2 -translate-x-1/2 shadow-sm border border-primary/20">{phase.step}</div>
                            <h4 class="font-headline-md text-headline-md text-on-background mb-2">{phase.title}</h4>
                            <p class="font-body-md text-body-md text-on-surface-variant">{phase.body}</p>
                        </article>
                    ))}
                </div>
            </div>
        </div>
    </section>
</Layout>
