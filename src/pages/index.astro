---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import prosperoHeroLogo from '../../public/images/project-logos/logo-desc-horizontal.svg';
---

<Layout title="PROSPERO - 6G Networks">
    <!-- Hero Section -->
    <section class="relative pt-32 pb-section-padding min-h-[50vh] flex items-center justify-center overflow-hidden bg-[url('/images/stock/abstract_6g_network_1782839922130.jpg')] bg-cover bg-center">
        <!-- Overlay to ensure the logo is highly visible -->
        <div class="absolute inset-0 bg-white/60 backdrop-blur-sm z-0"></div>
        
        <div class="relative z-10 max-w-container-max mx-auto px-8 flex justify-center items-center py-12">
            <Image src={prosperoHeroLogo} alt="PROSPERO: Programmable and Scalable Operations for Efficient, Resource-Aware Architecture in 6G Networks" class="w-full max-w-3xl h-auto drop-shadow-[0_10px_30px_rgba(0,0,0,0.1)]" decoding="async" fetchpriority="high" />
        </div>
    </section>

    <!-- Vision & Scope -->
    <section class="py-section-padding bg-surface-container-lowest relative z-10" id="vision">
        <div class="max-w-container-max mx-auto px-8">
            <div class="max-w-3xl mx-auto text-center space-y-stack-md mb-section-padding">
                <h2 class="font-headline-lg text-headline-lg text-sovereign-blue">Vision & Scope</h2>
                <p class="font-body-lg text-body-lg text-on-surface-variant">
                    PROSPERO envisions a sovereign, sustainable, and simplified 6G ecosystem. By converging connectivity, computing, and intelligence, we are establishing the foundation for resilient European technological sovereignty in the next generation of telecommunications.
                </p>
            </div>
            
            <!-- Strategic Paradigms Bento Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <!-- Paradigm 1 -->
                <div class="bg-white rounded-xl p-8 border border-glass-stroke shadow-[0_4px_20px_rgba(0,0,0,0.03)] hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] transition-shadow duration-300 border-t-4 border-t-primary col-span-1 md:col-span-2 lg:col-span-1">
                    <div class="w-12 h-12 rounded-full bg-eco-surface flex items-center justify-center text-primary mb-stack-sm">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">architecture</span>
                    </div>
                    <h3 class="font-headline-md text-headline-md text-on-background mb-2">Architectural Simplification</h3>
                    <p class="font-body-md text-body-md text-on-surface-variant">Reducing complexity through a Uniform, Integrated, and Simplified (UIS) framework.</p>
                </div>
                <!-- Paradigm 2 -->
                <div class="bg-white rounded-xl p-8 border border-glass-stroke shadow-[0_4px_20px_rgba(0,0,0,0.03)] hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] transition-shadow duration-300">
                    <div class="w-12 h-12 rounded-full bg-tertiary-fixed flex items-center justify-center text-tertiary mb-stack-sm">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">public</span>
                    </div>
                    <h3 class="font-headline-md text-headline-md text-on-background mb-2">Global Operations</h3>
                    <p class="font-body-md text-body-md text-on-surface-variant">Enabling borderless, scalable service provisioning across pan-European networks.</p>
                </div>
                <!-- Paradigm 3 -->
                <div class="bg-white rounded-xl p-8 border border-glass-stroke shadow-[0_4px_20px_rgba(0,0,0,0.03)] hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] transition-shadow duration-300">
                    <div class="w-12 h-12 rounded-full bg-secondary-fixed flex items-center justify-center text-secondary mb-stack-sm">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">memory</span>
                    </div>
                    <h3 class="font-headline-md text-headline-md text-on-background mb-2">Native AI Integration</h3>
                    <p class="font-body-md text-body-md text-on-surface-variant">Embedding AI at the core for predictive, autonomous network management.</p>
                </div>
                <!-- Paradigm 4 -->
                <div class="bg-white bg-prospero-texture bg-[length:600px_600px] bg-no-repeat bg-right-bottom rounded-xl p-8 border border-glass-stroke shadow-[0_4px_20px_rgba(0,0,0,0.03)] hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] transition-shadow duration-300 lg:col-span-2">
                    <div class="w-12 h-12 rounded-full bg-eco-surface flex items-center justify-center text-primary mb-stack-sm">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">eco</span>
                    </div>
                    <h3 class="font-headline-md text-headline-md text-on-background mb-2">Sustainability by Design</h3>
                    <p class="font-body-md text-body-md text-on-surface-variant">Prioritizing energy efficiency and resource awareness to minimize the environmental footprint of 6G infrastructure, aligning with European Green Deal objectives.</p>
                </div>
                <!-- Paradigm 5 -->
                <div class="bg-white rounded-xl p-8 border border-glass-stroke shadow-[0_4px_20px_rgba(0,0,0,0.03)] hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] transition-shadow duration-300">
                    <div class="w-12 h-12 rounded-full bg-surface-variant flex items-center justify-center text-earth-slate mb-stack-sm">
                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">account_tree</span>
                    </div>
                    <h3 class="font-headline-md text-headline-md text-on-background mb-2">Seamless Management</h3>
                    <p class="font-body-md text-body-md text-on-surface-variant">Unified orchestration across the compute and connectivity continuum.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Consortium Section -->
    <section class="py-section-padding bg-surface" id="consortium">
        <div class="max-w-container-max mx-auto px-8">
            <div class="text-center mb-section-padding">
                <h2 class="font-headline-lg text-headline-lg text-sovereign-blue mb-4">Consortium Partners</h2>
                <p class="font-body-md text-body-md text-on-surface-variant">Uniting Europe's leading innovators in telecommunications and research.</p>
            </div>
            <div id="partners-grid" class="grid grid-cols-2 md:grid-cols-4 gap-8 items-center justify-items-center opacity-70 max-w-4xl mx-auto">
                <!-- Injected via JS -->
                <p class="font-body-md">Loading partners...</p>
            </div>
        </div>
    </section>

    <script>
        // Load partners from data.json
        fetch('/data.json')
            .then(res => res.json())
            .then(data => {
                const partnersGrid = document.getElementById('partners-grid');
                if(data.partners && partnersGrid) {
                    let html = '';
                    data.partners.forEach((p: any) => {
                        html += `
                            <div class="w-32 md:w-40 h-20 flex items-center justify-center transition-all duration-300 grayscale hover:grayscale-0 relative group">
                                <img src="${p.logo}" alt="${p.name} logo" class="max-w-[120px] max-h-10 object-contain mx-auto" loading="lazy" decoding="async" />
                                <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 bg-sovereign-blue text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap z-20">
                                    ${p.name}
                                </div>
                            </div>
                        `;
                    });
                    partnersGrid.innerHTML = html;
                }
            })
            .catch(err => console.error(err));
    </script>
</Layout>
