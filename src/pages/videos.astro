---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Videos - PROSPERO">
    <section class="relative pt-32 pb-section-padding overflow-hidden bg-surface bg-[url('/images/project-logos/getsitelogo.png')] bg-contain bg-center bg-no-repeat">
        <div class="absolute inset-0 bg-white/60 backdrop-blur-sm z-0"></div>
        <div class="max-w-container-max mx-auto px-8 relative z-10 text-center">
            <h1 class="font-display-lg text-display-lg tracking-tight text-sovereign-blue mb-stack-md">Videos</h1>
            <p class="font-body-lg text-body-lg text-on-surface-variant max-w-3xl mx-auto">
                Talks, demos, interviews, and public presentation videos from PROSPERO.
            </p>
        </div>
    </section>

    <section class="py-section-padding bg-surface-container-lowest">
        <div class="max-w-3xl mx-auto px-8">
            <div class="bg-white rounded-xl p-8 border border-glass-stroke shadow-[0_4px_20px_rgba(0,0,0,0.03)] text-center">
                <span class="material-symbols-outlined text-primary text-4xl mb-4">smart_display</span>
                <h2 class="font-headline-md text-headline-md text-sovereign-blue mb-2">No videos published yet</h2>
                <p class="font-body-md text-body-md text-on-surface-variant">
                    Video content will be listed here once public project material is available.
                </p>
            </div>
        </div>
    </section>
</Layout>
