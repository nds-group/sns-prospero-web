---
import Layout from '../layouts/Layout.astro';

const objectives = [
    {
        heading: 'Transition towards a UIS 6G architecture',
        text: 'PROSPERO will evolve current mobile systems into a Uniform, Integrated, and Simplified architecture that joins connectivity, computing, and service platforms through open and globally applicable abstractions.',
        points: ['Virtualized Global Service-Based Architecture (vGSBA)', 'Compute Continuum Layer (CCL)', 'Evolved Zero Trust Layer (eZTL)'],
        icon: 'architecture',
    },
    {
        heading: 'Reduce Total Cost of Ownership',
        text: 'The project targets architectural, AI-driven, and resource-pooling innovations that reduce CAPEX and OPEX while improving energy efficiency across future 6G infrastructure.',
        points: ['Network-native AI in the CCL', 'Dynamic vDU scaling', 'AI-driven energy efficiency'],
        icon: 'savings',
    },
    {
        heading: 'Enable new revenue streams',
        text: 'PROSPERO explores business opportunities created by deep AI integration, shared compute resources, edge services, and secure access to rich network information.',
        points: ['AI-and-6G for shared RAN and AI workloads', 'AI-on-6G services using RAN data', 'Causal inference for planning and optimization'],
        icon: 'trending_up',
    },
    {
        heading: 'Enhance resilience and operational continuity',
        text: 'The project will design a Unified Telco HyperFabric that supports trusted global operations, resource pooling, and secure-by-default 6G infrastructure in critical scenarios.',
        points: ['Opportunistic telco resource pooling', 'Programmable in-network security', 'Confidential computing continuum'],
        icon: 'shield_lock',
    },
];

const impactItems = [
    'Green transition through energy-aware AI and efficient resource utilization.',
    'European competitiveness through open, software-based and AI-native 6G architectures.',
    'Technology sovereignty through resilient, adaptable and less proprietary infrastructure.',
];
---

<Layout title="Objectives & Impact - PROSPERO">
    <section class="relative pt-32 pb-section-padding overflow-hidden bg-surface bg-[url('/images/project-logos/getsitelogo.png')] bg-contain bg-center bg-no-repeat">
        <div class="absolute inset-0 bg-white/40 backdrop-blur-sm z-0"></div>
        <div class="max-w-container-max mx-auto px-8 relative z-10 text-center">
            <h1 class="font-display-lg text-display-lg tracking-tight text-sovereign-blue mb-stack-md">
                Objectives & Impact
            </h1>
            <div class="w-24 h-1 bg-gradient-to-r from-primary to-secondary mx-auto rounded-full mb-stack-lg"></div>
            <p class="font-body-lg text-body-lg text-on-surface-variant max-w-3xl mx-auto">
                PROSPERO defines, develops, and validates a pragmatic 6G architecture focused on economic sustainability, new service models, and resilience by design.
            </p>
        </div>
    </section>

    <section class="py-section-padding bg-surface-container-lowest">
        <div class="max-w-container-max mx-auto px-8">
            <div class="max-w-3xl mx-auto text-center mb-section-padding">
                <h2 class="font-headline-lg text-headline-lg text-sovereign-blue mb-stack-sm">Core Strategy</h2>
                <p class="font-body-lg text-body-lg text-on-surface-variant">
                    The project is built around one architectural objective and three operator-driven outcomes: lowering TCO, creating new revenue streams, and ensuring robust network resilience.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {objectives.map((objective) => (
                    <article class="bg-white rounded-xl p-8 border border-glass-stroke shadow-[0_4px_20px_rgba(0,0,0,0.03)] border-t-4 border-t-primary">
                        <div class="flex items-start gap-4 mb-stack-sm">
                            <div class="w-12 h-12 rounded-full bg-eco-surface flex items-center justify-center text-primary shrink-0">
                                <span class="material-symbols-outlined">{objective.icon}</span>
                            </div>
                            <div>
                                <h3 class="font-headline-md text-headline-md text-sovereign-blue">{objective.heading}</h3>
                            </div>
                        </div>
                        <p class="font-body-md text-body-md text-on-surface-variant mb-stack-sm">{objective.text}</p>
                        <ul class="space-y-2">
                            {objective.points.map((point) => (
                                <li class="flex gap-2 font-body-md text-body-md text-on-background">
                                    <span class="material-symbols-outlined text-primary text-[20px] mt-0.5">check_circle</span>
                                    <span>{point}</span>
                                </li>
                            ))}
                        </ul>
                    </article>
                ))}
            </div>
        </div>
    </section>

    <section class="py-section-padding bg-surface">
        <div class="max-w-container-max mx-auto px-8 grid grid-cols-1 lg:grid-cols-2 gap-gutter items-start">
            <div>
                <h2 class="font-headline-lg text-headline-lg text-sovereign-blue mb-stack-md">Performance Ambition</h2>
                <p class="font-body-lg text-body-lg text-on-surface-variant mb-stack-md">
                    PROSPERO will validate its innovations through measurable technology, business, and productivity KPIs. The work focuses on realistic experimental and data-driven settings, with prototypes and evaluations demonstrating viability across TCO reduction, revenue opportunities, and resilience.
                </p>
                <p class="font-body-md text-body-md text-on-surface-variant">
                    Key targets include resource utilization gains, RAN energy reduction, improved service accuracy, secure zero-trust service chains, and high service availability during large-scale disruption scenarios.
                </p>
            </div>
            <div class="bg-white rounded-xl p-8 border border-glass-stroke shadow-[0_4px_20px_rgba(0,0,0,0.03)]">
                <h3 class="font-headline-md text-headline-md text-primary mb-stack-sm">Expected Impact</h3>
                <ul class="space-y-4">
                    {impactItems.map((item) => (
                        <li class="flex gap-3 font-body-md text-body-md text-on-surface-variant">
                            <span class="material-symbols-outlined text-secondary text-[22px] mt-0.5">arrow_forward</span>
                            <span>{item}</span>
                        </li>
                    ))}
                </ul>
            </div>
        </div>
    </section>
</Layout>
